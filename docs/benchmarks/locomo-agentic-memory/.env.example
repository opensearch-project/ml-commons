# OpenSearch connection
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=your_password_here
OPENSEARCH_VERIFY_SSL=false

# AWS region (for Bedrock model calls)
AWS_REGION=us-east-1

# Bedrock model for answering questions (used by benchmark.py via boto3)
ANSWER_MODEL=us.anthropic.claude-sonnet-4-6

# OpenAI (for GPT-4o-mini judge — same evaluator as mem0 paper)
OPENAI_API_KEY=sk-your-key-here
JUDGE_MODEL=gpt-4o-mini

# OpenSearch ML model IDs (generated by setup.py — fill in after running it)
EMBEDDING_MODEL_ID=
LLM_MODEL_ID=

# Embedding dimension (1024 for Bedrock Titan v2, 1536 for OpenAI text-embedding-3-small)
EMBEDDING_DIMENSION=1024
